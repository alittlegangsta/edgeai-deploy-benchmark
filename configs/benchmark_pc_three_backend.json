  "rounds": {
    "count": 6,
    "warmup": 10,
    "repeat": 100,
    "order": [
      ["python_ort", "cpp_ort", "cpp_ncnn"],
      ["python_ort", "cpp_ncnn", "cpp_ort"],
      ["cpp_ort", "python_ort", "cpp_ncnn"],
      ["cpp_ort", "cpp_ncnn", "python_ort"],
      ["cpp_ncnn", "python_ort", "cpp_ort"],
      ["cpp_ncnn", "cpp_ort", "python_ort"]
    ]
  },
  "timing": {
    "stages": ["preprocess", "inference", "postprocess", "pipeline_total"],
    "pipeline_total_formula": "preprocess_ns + inference_ns + postprocess_ns",
    "excluded": [
      "image_file_read_and_decode",
      "model_load_and_runtime_creation",
      "visualization_and_labels",
