    "preserve_all_samples": true,
    "maximum_round_mean_relative_difference_percent": 10.0,
    "round_mean_spread_formula": "(max_round_mean - min_round_mean) / min_round_mean * 100",
    "position_mean_spread_formula": "(max_position_mean - min_position_mean) / min_position_mean * 100"
  },
  "resources": {
    "cpu_metric": "process_cpu_percent_one_core_basis",
    "cpu_formula": "100 * process_user_and_system_cpu_time_delta / wall_clock_time_delta",
    "peak_rss_formula_linux": "getrusage(RUSAGE_SELF).ru_maxrss * 1024",
